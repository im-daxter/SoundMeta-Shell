# Change artist name menu
artistName() {
    
    read -p "In Artist, Do you want all in one take? (Y/n): " confirm

    if [[ "$confirm" =~ ^[yY]$ ]]; then
    
    # Ask for the artist name
    read -p "Insert the Artist name: " NEW_ARTIST

    # 'For' to run in all playlist files
    for archive in *.mp3 *.wav *.ogg *.m4a *.flac; do
        
        # Verify if the file exist, if not continue
        [[ -e "$archive" ]] || continue
        echo -e "Editing the file: $archive"

        # Use mutagen or exiftool
        ffmpeg -i "$archive" -metadata artist="$NEW_ARTIST" -c:a copy -y "tmp_$archive" && mv "tmp_$archive" "$archive"

        echo "Task Conclued"
        sleep 1s
        clear

    done
    echo "Artist names edited with success!"

    else
    # 'For' to run in all playlist files
    for archive in *.mp3 *.wav *.ogg *.m4a *.flac; do
        
        # Verify if the file exist, if not continue
        [[ -e "$archive" ]] || continue
        echo -e "Editing the file: $archive"

        # Ask for the artist name
        read -p "Insert the artist name: " NEW_ARTIST

        # Confirm
        read -p "Confirm? (Y/n): " confirm
        if [[ "$confirm" =~ ^[nN]$ ]]; then
        echo "Action canceled to this file"
        continue
        fi

        # Use mutagen or exiftool
        ffmpeg -i "$archive" -metadata artist="$NEW_ARTIST" -c:a copy -y "tmp_$archive" && mv "tmp_$archive" "$archive"

        echo "Task Conclued"
        sleep 1s
        clear

    done
    echo "Artist names edited with success!"
    fi
}

