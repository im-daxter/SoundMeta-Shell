loopin() {

    # Global variables and questions
    read -p "Insert the Album's name: " NEW_ALBUM

    # 'For' to run in all playlist files
    for archive in *.mp3 *.wav *.ogg *.m4a *.flac; do 

    # Verify if the file exist, if not continue
    [[ -e "$archive" ]] || continue

    echo -e "Editing the file: $archive"

    # Ask for the title and track number
    read -p "Insert the track number: " NEW_TRACK
    read -p "Insert the track title: " NEW_TITLE
    read -p "Insert the artist name: " NEW_ARTIST
    
    # Resume of the informations
    echo -e "\nRESUME: "
    echo "Track: $NEW_TRACK"
    echo "Title: $NEW_TITLE"
    echo "Artist: $NEW_ARTIST"
    echo "Album: $NEW_ALBUM"

    # Confirm
    read -p "Confirm? (Y/n): " confirm

    if [[ "$confirm" =~ ^[nN]$ ]]; then
        echo "Action canceled to this file"
        continue
    fi

    # Use mutagen or exiftool
    ffmpeg -i "$archive" -metadata artist="$NEW_ARTIST" -metadata album="$NEW_ALBUM" -metadata title="$NEW_TITLE" -metadata track="$NEW_TRACK" -c:a copy -y "tmp_$archive" && mv "tmp_$archive" "$archive"

    echo "Task Conclued"
    sleep 1s
    clear

    done
    echo -e "\nPlaylist modified with success"
}

# Define the Directory
DIR=$(pwd)

while true; do
    clear
    echo "Actual Directory: $DIR"

    # Header of the Menu
    echo "========================================="
    echo "          MUSIC METADATA EDITOR          "
    echo "========================================="
    echo "  CHOOSE AN OPTION:"
    echo "-----------------------------------------"
    echo "  1) Change Only Artist"
    echo "  2) Change Only Title"
    echo "  3) Change Only Number"
    echo "  4) Change Only Album"
    echo "  5) Change All in one Take"
    echo "  6) Exit"
    echo "========================================="
    read -p "Insert an option: " option

    # Menu
    case "$option" in
    1)
            echo -e "\nChange Artist"
        artistName
            read -p "Press Enter to continue..."
            ;;
    2)
            echo -e "\nChange Title"
        title
            read -p "Press Enter to continue..."
            ;;
    3)
            echo -e "\nChange Track number"
        trackNumber
            read -p "Press Enter to continue..."
            ;;
    4)
            echo -e "\nChange Album"
        albumName
            read -p "Press Enter to continue..."
            ;;
    5)
            echo -e "\nStarting Loopin Mode..."
            loopin
            read -p "Press Enter to continue..."
            ;;
    6)
            echo "Quitting..."
            exit 0
            ;;
    *)
            echo "Invalid Option!!"
        sleep 1
            ;;
    esac
done
